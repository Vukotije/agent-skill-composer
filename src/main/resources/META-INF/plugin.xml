<idea-plugin>
    <id>com.vukan.agentskillcomposer.agent-skill-composer</id>
    <name>Agent Skill Composer</name>
    <vendor url="https://github.com/Vukotije">Vukan</vendor>

    <description><![CDATA[
        Analyzes Kotlin/Java project conventions and generates AI-backed agent guidance
        artifacts for Junie and Claude Code.
    ]]></description>

    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Agent Skill Composer"
                    factoryClass="com.vukan.agentskillcomposer.ui.AgentSkillToolWindowFactory"
                    icon="AllIcons.Actions.ProjectWideAnalysis"/>

        <projectService
                serviceInterface="com.vukan.agentskillcomposer.analysis.ProjectAnalyzer"
                serviceImplementation="com.vukan.agentskillcomposer.analysis.impl.DefaultProjectAnalyzer"/>

        <applicationService
                serviceImplementation="com.vukan.agentskillcomposer.settings.PluginSettings"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.vukan.agentskillcomposer.settings.PluginSettingsConfigurable"
                id="com.vukan.agentskillcomposer.settings"
                displayName="Agent Skill Composer"/>

        <notificationGroup id="Agent Skill Composer"
                           displayType="BALLOON"/>
    </extensions>
</idea-plugin>
